{
  "name": "xcss-scaffold",
  "version": "0.0.12",
  "configs": {
    "name": "scaffold",
    "version": "0.0.12",
    "sandbox": "sandbox",
    "blueprint": "blueprint",
    "libraries": "libraries"
  },
  "scripts": {
    "lib:compile": "npx sass libsource:libraries --no-source-map",
    "lib:watch": "npx sass --watch libsource:libraries --no-source-map",
    "build": "npm run lib:compile "
  },
  "type": "module",
  "description": "Template for creating flavours for XCSS.",
  "license": "MIT",
  "homepage": "https://www.xcss.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/yshelldev/xcss-scaffold"
  },
  "author": {
    "name": "Vyshnav Prasad",
    "url": "https://www.yshell.dev"
  },
  "bugs": {
    "url": "https://github.com/yshelldev/xcss-scaffold/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/yshelldev"
  },
  "keywords": [
    "css",
    "xcss-template",
    "css-framework"
  ],
  "dev-dependencies": {
    "sass": "^1.94.2"
  }
}